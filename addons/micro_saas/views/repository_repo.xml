        <field name="name">repository.repo.tree</field>
        <field name="model">repository.repo</field>
        <field name="arch" type="xml">
            <list string="Repository and Branch" editable="bottom">
                <field name="name"/>
            </list>
        </field>
    </record>
</odoo>
