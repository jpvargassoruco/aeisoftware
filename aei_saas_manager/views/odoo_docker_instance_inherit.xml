<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_odoo_docker_instance_form_inherit_cf" model="ir.ui.view">
        <field name="name">odoo.docker.instance.form.inherit.cf</field>
        <field name="model">odoo.docker.instance</field>
        <field name="inherit_id" ref="micro_saas.view_odoo_docker_instance_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="domain_name" placeholder="e.g. app1.aeisoftware.com"/>
                <field name="cloudflare_status" widget="badge" decoration-success="cloudflare_status == 'published'" decoration-danger="cloudflare_status == 'failed'"/>
            </xpath>
        </field>
    </record>
</odoo>
